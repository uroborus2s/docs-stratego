{
  "version": 3,
  "default_source_mode": "local",
  "repositories": [
    {
      "name": "docs-stratego",
      "title": "章略·墨衡",
      "repo_url": "https://github.com/uroborus2s/stratego-docs",
      "modes": {
        "local": {
          "source_type": "local",
          "local_path": "docs"
        },
        "remote": {
          "source_type": "local",
          "local_path": "docs"
        }
      }
    },
    {
      "name": "crawler4j",
      "title": "蛛行演略",
      "repo_url": "https://github.com/uroborus2s/crawler4j",
      "modes": {
        "local": {
          "source_type": "local",
          "local_path": "../../PythonProject/crawler4j/docs"
        },
        "remote": {
          "source_type": "submodule_sparse",
          "git_url": "https://github.com/uroborus2s/crawler4j.git",
          "branch": "feature/task-plugin-system",
          "submodule_path": "sources/crawler4j",
          "docs_path": "docs"
        }
      }
    },
    {
      "name": "stratix",
      "title": "灵枢枢机",
      "repo_url": "https://github.com/uroborus2s/obsync-root",
      "modes": {
        "local": {
          "source_type": "local",
          "local_path": "../../NodeProject/wps/obsync-root/docs"
        },
        "remote": {
          "source_type": "submodule_sparse",
          "git_url": "https://github.com/uroborus2s/obsync-root.git",
          "branch": "main",
          "submodule_path": "sources/stratix",
          "docs_path": "docs"
        }
      }
    },
    {
      "name": "ride-loop",
      "title": "千乘坊",
      "repo_url": "https://github.com/uroborus2s/ride-loop",
      "modes": {
        "local": {
          "source_type": "local",
          "local_path": "../../NodeProject/ride-loop/docs"
        },
        "remote": {
          "source_type": "submodule_sparse",
          "git_url": "https://github.com/uroborus2s/ride-loop.git",
          "branch": "main",
          "submodule_path": "sources/ride-loop",
          "docs_path": "docs"
        }
      }
    }
  ]
}
